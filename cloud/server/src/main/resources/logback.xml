<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %X{call-id} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="debug">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>
    <logger name="org.testcontainers" level="INFO"/>
    <logger name="tc" level="INFO"/>
    <logger name="com.github.dockerjava" level="WARN"/>
    <logger name="com.github.dockerjava.zerodep.shaded.org.apache.hc.client5.http.wire" level="OFF"/>
    <logger name="org.apache.http" level="WARN"/>
    <logger name="org.apache.hc" level="OFF"/>

    <logger name="io.r2dbc.postgresql.client" level="INFO"/>
    <logger name="io.r2dbc.postgresql.util" level="INFO"/>
    <logger name="io.r2dbc.postgresql.QUERY" level="INFO"/>
    <logger name="io.r2dbc.postgresql.PARAM" level="INFO"/>
    <logger name="io.r2dbc.h2.client" level="INFO"/>
    <logger name="reactor.netty.tcp.TcpResources" level="INFO"/>
    <logger name="reactor.netty.ReactorNetty" level="INFO"/>
    <logger name="reactor.netty.transport" level="INFO"/>
    <logger name="reactor.netty.channel" level="INFO"/>
    <logger name="reactor.netty.resources" level="INFO"/>
</configuration>